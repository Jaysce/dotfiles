#!/bin/sh
# Small tmux entrypoint shared by zsh and fish.
# Usage:
#   tmx              attach to the last session, or create "main"
#   tmx --new        create a new session and open the Sesh picker
#   tmx <directory>  create/switch to a session named after that directory

set -u

tmux_config_file=${TMUX_CONFIG_DIR:-$HOME/.config/tmux}/tmux.conf

tmux_cmd() {
  if [ -f "$tmux_config_file" ]; then
    tmux -f "$tmux_config_file" "$@"
  else
    tmux "$@"
  fi
}

usage() {
  cat <<'EOF'
Usage:
  tmx              Attach to the last tmux session, or create "main"
  tmx -n|--new     Create a new tmux session and open the Sesh picker
  tmx <directory>  Create/switch to a tmux session for that directory
  tmx -h|--help    Show this help
EOF
}

sanitize_session_name() {
  basename "$1" | tr ' .:' '___'
}

has_sessions() {
  tmux_cmd list-sessions >/dev/null 2>&1
}

new_session_name() {
  if ! tmux_cmd has-session -t main 2>/dev/null; then
    printf '%s\n' main
  else
    printf 'session-%s\n' "$(date +%s)"
  fi
}

new_session_mode() {
  session_name=$(new_session_name)
  start_dir=$HOME

  if [ -n "${TMUX:-}" ]; then
    tmux_cmd new-session -d -s "$session_name" -c "$start_dir"
    tmux_cmd switch-client -t "$session_name"
    tmux_cmd run-shell "$TMUX_CONFIG_DIR/scripts/sesh-or-stay.sh '$session_name'"
  else
    tmux_cmd new-session -s "$session_name" -c "$start_dir" \; run-shell "$TMUX_CONFIG_DIR/scripts/sesh-or-stay.sh '$session_name'"
  fi
}

attach_or_create_main() {
  if has_sessions; then
    if [ -n "${TMUX:-}" ]; then
      tmux_cmd switch-client -l 2>/dev/null || tmux_cmd switch-client -t main 2>/dev/null || {
        tmux_cmd new-session -d -s main -c "$HOME"
        tmux_cmd switch-client -t main
      }
    else
      tmux_cmd attach-session
    fi
  else
    if [ -n "${TMUX:-}" ]; then
      tmux_cmd new-session -d -s main -c "$HOME"
      tmux_cmd switch-client -t main
    else
      tmux_cmd new-session -s main -c "$HOME"
    fi
  fi
}

switch_to_directory() {
  target=$1

  if ! cd "$target" 2>/dev/null; then
    printf 'tmx: not a directory: %s\n' "$target" >&2
    exit 1
  fi

  dir=$(pwd)
  session_name=$(sanitize_session_name "$dir")
  [ -n "$session_name" ] || session_name=main

  if [ -n "${TMUX:-}" ]; then
    tmux_cmd new-session -A -d -s "$session_name" -c "$dir"
    tmux_cmd switch-client -t "$session_name"
  else
    tmux_cmd new-session -A -s "$session_name" -c "$dir"
  fi
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
  -n|--new)
    new_session_mode
    ;;
  "")
    attach_or_create_main
    ;;
  *)
    if [ "$#" -ne 1 ]; then
      usage >&2
      exit 1
    fi
    switch_to_directory "$1"
    ;;
esac
