#!/bin/sh
# Pick a file with fzf and open it in $EDITOR inside the popup.

set -u

editor=${EDITOR:-nvim}
fd_cmd=${FD:-fd}
bat_cmd=${BAT:-bat}

if ! command -v "$fd_cmd" >/dev/null 2>&1; then
  printf 'tmux-fzf-files: fd is required\n' >&2
  exit 1
fi

file=$(
  "$fd_cmd" --type f --hidden --follow --exclude .git 2>/dev/null |
    fzf --prompt='Files> ' --preview "$bat_cmd --style=numbers --color=always {} 2>/dev/null" --preview-window=right:60%
)

[ -n "$file" ] || exit 0
exec "$editor" "$file"
