#!/bin/sh
# Pick a zoxide directory and switch/create a tmux session for it.

set -u

if command -v zoxide >/dev/null 2>&1; then
  source_cmd='zoxide query -l'
else
  source_cmd='fd --type d --max-depth 3 . "$HOME"'
fi

preview='eza --tree --level=2 --color=always {} 2>/dev/null || ls -la {} 2>/dev/null'

dir=$(
  sh -c "$source_cmd" |
    fzf --prompt='Projects> ' --preview "$preview" --preview-window=right:60%
)

[ -n "$dir" ] || exit 0
exec "$HOME/.local/bin/tmx" "$dir"
