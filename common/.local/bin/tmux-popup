#!/bin/sh
# Standardized tmux popup launcher.
# Usage: tmux-popup [-s xsmall|small|medium|large|full] [-t title] [-d dir] [-w width] [-h height] [-E] command...

set -eu

size=medium
title=
dir="#{pane_current_path}"
custom_width=
custom_height=
exit_on_close=

while [ "$#" -gt 0 ]; do
  case "$1" in
    -s|--size)
      size=$2
      shift 2
      ;;
    -t|--title)
      title=$2
      shift 2
      ;;
    -d|--dir)
      dir=$2
      shift 2
      ;;
    -w|--width)
      custom_width=$2
      shift 2
      ;;
    -h|--height)
      custom_height=$2
      shift 2
      ;;
    -E|--exit-on-close)
      exit_on_close=1
      shift
      ;;
    -H|--help)
      sed -n '2,3p' "$0"
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      printf 'tmux-popup: unknown option: %s\n' "$1" >&2
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

[ "$#" -gt 0 ] || {
  printf 'tmux-popup: command required\n' >&2
  exit 1
}

if [ -z "${TMUX:-}" ]; then
  exec "$@"
fi

case "$size" in
  xsmall)
    width=60%
    height=20
    ;;
  small)
    width=80%
    height=70%
    ;;
  medium)
    term_width=$(tmux display-message -p '#{window_width}')
    term_height=$(tmux display-message -p '#{window_height}')
    width_90=$((term_width * 90 / 100))
    height_90=$((term_height * 90 / 100))
    [ "$width_90" -gt 250 ] && width=250 || width=90%
    [ "$height_90" -gt 100 ] && height=100 || height=90%
    ;;
  large)
    width=90%
    height=90%
    ;;
  full)
    width=100%
    height=100%
    ;;
  *)
    printf 'tmux-popup: invalid size: %s\n' "$size" >&2
    exit 1
    ;;
esac

width=${custom_width:-$width}
height=${custom_height:-$height}

term_width=${term_width:-$(tmux display-message -p '#{window_width}')}
term_height=${term_height:-$(tmux display-message -p '#{window_height}')}
max_width=$((term_width * 90 / 100))
max_height=$((term_height * 90 / 100))

case "$width" in
  *%) ;;
  *) [ "$width" -gt "$max_width" ] && width=$max_width ;;
esac

case "$height" in
  *%) ;;
  *) [ "$height" -gt "$max_height" ] && height=$max_height ;;
esac

[ -n "$exit_on_close" ] && set -- -E "$@"
set -- -w "$width" -h "$height" -d "$dir" -e TMUX_IN_POPUP=1 "$@"
[ -n "$title" ] && set -- -T "$title" "$@"

exec tmux display-popup "$@"
