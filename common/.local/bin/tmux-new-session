#!/bin/sh
# Create a new tmux session, switch to it, then open the Sesh picker.

set -eu

tmux_config_file=${TMUX_CONFIG_DIR:-$HOME/.config/tmux}/tmux.conf

tmux_cmd() {
  if [ -f "$tmux_config_file" ]; then
    tmux -f "$tmux_config_file" "$@"
  else
    tmux "$@"
  fi
}

case "${1:-}" in
  -h|--help)
    cat <<'EOF'
Usage:
  tmux-new-session [session-name]

Create a new tmux session, switch to it, then open the Sesh picker.
EOF
    exit 0
    ;;
esac

session_name=${1:-}

if [ -z "$session_name" ]; then
  session_name="session-$(date +%s)"
fi

if [ -n "${TMUX:-}" ]; then
  tmux_cmd new-session -d -s "$session_name" -c "${PWD:-$HOME}"
  tmux_cmd switch-client -t "$session_name"
  tmux_cmd run-shell "$TMUX_CONFIG_DIR/scripts/sesh-or-stay.sh '$session_name'"
else
  tmux_cmd new-session -s "$session_name" -c "${PWD:-$HOME}" \; run-shell "$TMUX_CONFIG_DIR/scripts/sesh-or-stay.sh '$session_name'"
fi
