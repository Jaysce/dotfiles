"" Base Settings
"" ========================================================

let mapleader = " "

" General settings
set scrolloff=10
set linenumber
set relativenumber
set showmode
set showcmd
set visualbell
set clipboard+=unnamed
set notimeout
set ideajoin

" Search improvements
set ignorecase
set smartcase
set incsearch
set hlsearch


"" Plugin Settings
"" ========================================================
set surround
set commentary
set highlightedyank
set sneak " https://plugins.jetbrains.com/plugin/15348-ideavim-sneak
set nerdtree
set which-key " https://github.com/brandonkramer/which-key-lazy

" Which Key Lazy discovers leader mappings automatically. These descriptions
