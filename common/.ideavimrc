"" Key mappings
"" ========================================================

" Save from normal, insert, and visual modes
nmap <C-s> <Action>(SaveAll)
imap <C-s> <Action>(SaveAll)
vmap <C-s> <Action>(SaveAll)

" Move by display line unless a count is provided
nnoremap <expr> j v:count == 0 ? 'gj' : 'j'
vnoremap <expr> j v:count == 0 ? 'gj' : 'j'
nnoremap <expr> <Down> v:count == 0 ? 'gj' : 'j'
vnoremap <expr> <Down> v:count == 0 ? 'gj' : 'j'
nnoremap <expr> k v:count == 0 ? 'gk' : 'k'
vnoremap <expr> k v:count == 0 ? 'gk' : 'k'
nnoremap <expr> <Up> v:count == 0 ? 'gk' : 'k'
vnoremap <expr> <Up> v:count == 0 ? 'gk' : 'k'

" Pane navigation and resizing
nnoremap <C-h> <C-w>h
nnoremap <C-l> <C-w>l
nnoremap <C-k> <C-w>k
nnoremap <C-j> <C-w>j
nmap <C-Up> <Action>(StretchSplitToTop)
nmap <C-Down> <Action>(StretchSplitToBottom)
nmap <C-Left> <Action>(StretchSplitToLeft)
nmap <C-Right> <Action>(StretchSplitToRight)

" Buffer navigation
nmap <S-h> <Action>(PreviousTab)
nmap <S-l> <Action>(NextTab)
nmap [b <Action>(PreviousTab)
nmap ]b <Action>(NextTab)

" LSP-style navigation
nmap gd <Action>(GotoDeclaration)
nmap gD <Action>(GotoDeclaration)
nmap gI <Action>(GotoImplementation)
nmap gy <Action>(GotoTypeDeclaration)
nmap gr <Action>(FindUsages)
nmap K <Action>(QuickJavaDoc)
nmap gK <Action>(ParameterInfo)
imap <C-k> <Action>(ParameterInfo)
nmap [[ <Action>(GotoPrevElementUnderCaretUsage)
nmap ]] <Action>(GotoNextElementUnderCaretUsage)

" Easy visual indentation
vnoremap < <gv
vnoremap > >gv

" Move lines
nmap <A-j> <Action>(MoveLineDown)
nmap <A-k> <Action>(MoveLineUp)
imap <A-j> <Action>(MoveLineDown)
imap <A-k> <Action>(MoveLineUp)
vmap <A-j> <Action>(MoveLineDown)
vmap <A-k> <Action>(MoveLineUp)

" Navigate diagnostics and quickfix items
nmap [d <Action>(GotoPreviousError)
nmap ]d <Action>(GotoNextError)
nmap [e <Action>(GotoPreviousError)
nmap ]e <Action>(GotoNextError)
nmap [w <Action>(GotoPreviousError)
nmap ]w <Action>(GotoNextError)
nmap [q <Action>(GotoPreviousError)
nmap ]q <Action>(GotoNextError)

" Center search results and open folds
nnoremap n nzzzv
nnoremap N Nzzzv

"" Leader commands
"" ========================================================

" Root mappings
nmap <leader><Space> <Action>(GotoFile)
nmap <leader>, <Action>(Switcher)
nmap <leader>/ <Action>(FindInPath)
nmap <leader>: <Action>(GotoAction)
nmap <leader>? :map<CR>
nnoremap <leader>` <C-^>
nmap <leader>. <Action>(NewScratchBuffer)
nmap <leader>S <Action>(Scratch.ShowFilesPopup)
nmap <leader>e :NERDTreeToggle<CR>
nmap <leader>E <Action>(SelectInProjectView)

" Harpoon (requires HarpoonIJ)
nmap <leader>a <Action>(AddToHarpoon)
nmap <leader>h <Action>(ShowHarpoon)
nmap <leader>1 <Action>(GotoHarpoon1)
nmap <leader>2 <Action>(GotoHarpoon2)
nmap <leader>3 <Action>(GotoHarpoon3)
nmap <leader>4 <Action>(GotoHarpoon4)
nmap <C-S-P> <Action>(PreviousHarpoonItem)
nmap <C-S-N> <Action>(NextHarpoonItem)

" Buffers
nnoremap <leader>bb <C-^>
nmap <leader>bd <Action>(CloseContent)
nmap <leader>bo <Action>(CloseAllEditorsButActive)

" Code
nmap <leader>ca <Action>(ShowIntentionActions)
vmap <leader>ca <Action>(ShowIntentionActions)
nmap <leader>cd <Action>(ShowErrorDescription)
nmap <leader>cf <Action>(ReformatCode)
vmap <leader>cf <Action>(ReformatCode)
nmap <leader>co <Action>(OptimizeImports)
nmap <leader>cr <Action>(RenameElement)
nmap <leader>cR <Action>(RenameFile)
nmap <leader>cS <Action>(FindUsages)

" File/find
nmap <leader>fb <Action>(Switcher)
nmap <leader>fe :NERDTreeToggle<CR>
nmap <leader>fE <Action>(SelectInProjectView)
nmap <leader>ff <Action>(GotoFile)
nmap <leader>fn <Action>(NewElement)
nmap <leader>fp <Action>(ManageRecentProjects)
nmap <leader>fr <Action>(RecentFiles)
nmap <leader>ft <Action>(ActivateTerminalToolWindow)
nmap <C-/> <Action>(ActivateTerminalToolWindow)
nmap <C-_> <Action>(ActivateTerminalToolWindow)

" Git
nmap <leader>gb <Action>(Annotate)
nmap <leader>gd <Action>(Vcs.ShowDiffWithLocal)
nmap <leader>gf <Action>(Vcs.ShowTabbedFileHistory)
nmap <leader>gg <Action>(ActivateVersionControlToolWindow)
nmap <leader>gl <Action>(Vcs.Show.Log)
nmap <leader>gs <Action>(ActivateCommitToolWindow)

" Quit/session
nmap <leader>qq <Action>(Exit)

" IntelliJ refactorings
nmap <leader>rm <Action>(ExtractMethod)
nmap <leader>rv <Action>(IntroduceVariable)
nmap <leader>rf <Action>(IntroduceField)
nmap <leader>rs <Action>(ChangeSignature)
nmap <leader>rr <Action>(Refactorings.QuickListPopupAction)

" Search
nmap <leader>s" :registers<CR>
nmap <leader>s/ <Action>(ShowSearchHistory)
nmap <leader>sb <Action>(Find)
nmap <leader>sC <Action>(GotoAction)
nmap <leader>sg <Action>(FindInPath)
nmap <leader>sj :jumps<CR>
nmap <leader>sk :map<CR>
nmap <leader>sm :marks<CR>
nmap <leader>sr <Action>(ReplaceInPath)
nmap <leader>ss <Action>(FileStructurePopup)
nmap <leader>sS <Action>(GotoSymbol)
nmap <leader>sw <Action>(FindInPath)
vmap <leader>sw <Action>(FindInPath)

" Tabs
nmap <leader><Tab>[ <Action>(PreviousTab)
nmap <leader><Tab>] <Action>(NextTab)

" UI
nmap <leader>uC <Action>(QuickChangeScheme)
nmap <leader>uD <Action>(ToggleDistractionFreeMode)
nmap <leader>uL :set relativenumber!<CR>
nmap <leader>uZ <Action>(MaximizeEditorInSplit)
nmap <leader>uh <Action>(ToggleInlayHintsGloballyAction)
nmap <leader>ul <Action>(EditorToggleShowLineNumbers)
nmap <leader>un <Action>(CloseAllNotifications)
nmap <leader>ur :nohlsearch<CR>
nmap <leader>uw <Action>(EditorToggleUseSoftWraps)
nmap <leader>uz <Action>(ToggleZenMode)

" Windows
nmap <leader>- <Action>(SplitHorizontally)
nmap <leader>\| <Action>(SplitVertically)
nmap <leader>wm <Action>(MaximizeEditorInSplit)

" Diagnostics
nmap <leader>xx <Action>(ActivateProblemsViewToolWindow)

" Yank path
nmap <leader>ya <Action>(CopyAbsolutePath)
nmap <leader>yr <Action>(CopyContentRootPath)
nmap <leader>yf <Action>(CopyFileName)
